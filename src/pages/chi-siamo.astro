---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const team = [
  { nome: "Dott. Marco Bricco", ruolo: "Presidente", img: "https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=400&q=80&auto=format&fit=crop&crop=face" },
  { nome: "Dott.ssa Laura Ferrero", ruolo: "Vice Presidente", img: "https://images.unsplash.com/photo-1594824476967-48c8b964273f?w=400&q=80&auto=format&fit=crop&crop=face" },
  { nome: "Inf. Giovanni Tarditi", ruolo: "Segretario", img: "https://images.unsplash.com/photo-1622253692010-333f2da6031d?w=400&q=80&auto=format&fit=crop&crop=face" },
  { nome: "Dott. Stefano Morra", ruolo: "Consigliere", img: "https://images.unsplash.com/photo-1537368910025-700350fe46c7?w=400&q=80&auto=format&fit=crop&crop=face" },
  { nome: "Dott.ssa Anna Rossi", ruolo: "Consigliere", img: "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=400&q=80&auto=format&fit=crop&crop=face" },
  { nome: "Inf. Paolo Gallo", ruolo: "Consigliere", img: "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?w=400&q=80&auto=format&fit=crop&crop=face" },
];
---

<Layout title="Chi siamo" description="Scopri chi siamo: volontari, medici e infermieri uniti per la salute della comunità di Savigliano.">
  <Nav />

  <main>
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="page-hero-bg">
        <img src="https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=1400&q=75&auto=format&fit=crop" alt="Team CuoreinMente" loading="eager" />
        <div class="page-hero-overlay"></div>
      </div>
      <div class="container page-hero-content">
        <div class="breadcrumb">
          <a href="/">Home</a>
          <span>/</span>
          <span>Chi siamo</span>
        </div>
        <h1 class="page-title">Chi <em>siamo</em></h1>
        <p class="page-subtitle">Volontari, medici e cittadini uniti da un obiettivo comune: la salute di tutti.</p>
      </div>
    </section>

    <!-- Presentazione -->
    <section class="section-pad">
      <div class="container two-col">
        <div class="col-text">
          <div class="eyebrow">La nostra storia</div>
          <h2 class="section-h2">Presentiamoci.</h2>
          <p>Cuore in Mente è una <strong>Associazione di prevenzione e promozione sociale</strong>, nata a Savigliano (CN) nel <strong>2018</strong>.</p>
          <p>Il suo consiglio direttivo e i suoi membri attivi sono costituiti da semplici cittadini, medici e infermieri, <strong>tutti volontari</strong>, che si sono riuniti nell'interesse di creare una realtà che avvicinasse i cittadini al tema della salute pubblica, nello specifico delle malattie neuro-cardiovascolari e della cura precoce dell'arresto cardiaco.</p>
          <p>L'Associazione ha scopi promozionali, preventivi ed educativi, che vengono concretizzati attraverso attività di tipo <strong>informativo, educativo, sportivo e formativo</strong> rivolti alla collettività.</p>
          <div class="info-box">
            <div class="info-row">
              <span class="info-label">Sede legale</span>
              <span>P.zza Schiaparelli 10, 12038 Savigliano (CN)</span>
            </div>
            <div class="info-row">
              <span class="info-label">Codice fiscale</span>
              <span>94048590049</span>
            </div>
            <div class="info-row">
              <span class="info-label">Fondata nel</span>
              <span>2018</span>
            </div>
          </div>
        </div>
        <div class="col-visual">
          <img class="about-img" src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=700&q=80&auto=format&fit=crop" alt="Il nostro lavoro" loading="lazy" />
          <div class="stat-floating">
            <div class="stat-big">100%</div>
            <div class="stat-desc">Volontari non retribuiti</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Valori -->
    <section class="values-section">
      <div class="container">
        <div class="eyebrow" style="text-align:center">I nostri valori</div>
        <h2 class="section-h2" style="text-align:center;margin-bottom:48px">Cosa ci guida ogni giorno</h2>
        <div class="values-grid">
          {[
            { icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, titolo: "Comunità", desc: "Lavoriamo per il bene collettivo, non per interessi personali. Ogni azione è rivolta alla collettività." },
            { icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, titolo: "Trasparenza", desc: "Gestiamo l'associazione nella totale trasparenza verso i soci e verso la comunità." },
            { icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`, titolo: "Prevenzione", desc: "Crediamo che prevenire sia sempre meglio che curare. Per questo investiamo in formazione e informazione." },
            { icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`, titolo: "Competenza", desc: "Il nostro team include medici e infermieri professionisti che garantiscono la qualità di ogni attività." },
          ].map(v => (
            <div class="value-card">
              <div class="value-icon" set:html={v.icon} />
              <h3 class="value-title">{v.titolo}</h3>
              <p class="value-desc">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Il Direttivo -->
    <section class="section-pad">
      <div class="container">
        <div class="eyebrow">Le persone</div>
        <h2 class="section-h2">Il direttivo.</h2>
        <p class="section-intro">Guidiamo la nostra associazione nella totale trasparenza, con un unico obiettivo: il bene della collettività.</p>
        <div class="team-grid">
          {team.map(m => (
            <div class="team-card">
              <div class="team-img-wrap">
                <img src={m.img} alt={m.nome} loading="lazy" />
              </div>
              <div class="team-body">
                <h3 class="team-name">{m.nome}</h3>
                <span class="team-role">{m.ruolo}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-strip">
      <div class="container cta-inner">
        <h2>Vuoi unirti a noi?</h2>
        <p>L'associazione è sempre aperta a nuovi volontari. Contattaci per saperne di più.</p>
        <a href="/contatti" class="btn-cta">Contattaci</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
/* ── Page Hero ── */
.page-hero { position:relative; min-height:420px; display:flex; align-items:flex-end; padding-bottom:64px; background:#111; overflow:hidden; }
.page-hero-bg { position:absolute; inset:0; }
.page-hero-bg img { width:100%; height:100%; object-fit:cover; opacity:0.4; }
.page-hero-overlay { position:absolute; inset:0; background:linear-gradient(to top, rgba(10,5,5,0.85) 0%, rgba(10,5,5,0.3) 100%); }
.page-hero-content { position:relative; z-index:10; }
.breadcrumb { display:flex; gap:8px; align-items:center; font-size:12px; color:rgba(255,255,255,0.4); margin-bottom:20px; }
.breadcrumb a { color:rgba(255,255,255,0.5); transition:color .2s; }
.breadcrumb a:hover { color:white; }
.page-title { font-family:var(--font-display); font-size:clamp(44px,6vw,72px); font-weight:400; color:white; margin-bottom:12px; }
.page-title em { font-style:italic; color:#E87B6B; }
.page-subtitle { font-size:16px; color:rgba(255,255,255,0.65); max-width:480px; line-height:1.65; }

/* ── Sections ── */
.section-pad { padding:88px 0; }
.eyebrow { font-size:11px; font-weight:500; color:var(--red); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:12px; }
.section-h2 { font-family:var(--font-display); font-size:clamp(30px,4vw,44px); font-weight:400; color:var(--ink); margin-bottom:24px; }
.section-intro { font-size:15px; color:var(--ink-muted); line-height:1.7; max-width:560px; margin-bottom:48px; }

/* ── Two col ── */
.two-col { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start; }
.col-text p { font-size:15px; color:var(--ink-muted); line-height:1.75; margin-bottom:16px; }
.col-text strong { color:var(--ink); font-weight:500; }
.info-box { margin-top:32px; border:0.5px solid var(--cream-border); border-radius:var(--radius-md); overflow:hidden; }
.info-row { display:flex; justify-content:space-between; align-items:center; padding:14px 20px; font-size:13px; border-bottom:0.5px solid var(--cream-border); }
.info-row:last-child { border-bottom:none; }
.info-label { color:var(--ink-faint); font-weight:400; }
.col-visual { position:relative; }
.about-img { width:100%; height:420px; object-fit:cover; border-radius:var(--radius-md); }
.stat-floating { position:absolute; bottom:-20px; left:-20px; background:var(--red); color:white; padding:20px 24px; border-radius:var(--radius-md); box-shadow:0 8px 32px rgba(192,57,43,0.35); }
.stat-big { font-family:var(--font-display); font-size:36px; line-height:1; }
.stat-desc { font-size:11px; opacity:0.8; margin-top:4px; text-transform:uppercase; letter-spacing:0.5px; }

/* ── Values ── */
.values-section { padding:88px 0; background:var(--cream); border-top:0.5px solid var(--cream-border); }
.values-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; }
.value-card { background:white; border:0.5px solid var(--cream-border); border-radius:var(--radius-md); padding:28px 24px; }
.value-icon { width:48px; height:48px; background:var(--red-light); border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; color:var(--red); margin-bottom:16px; }
.value-title { font-size:15px; font-weight:500; color:var(--ink); margin-bottom:8px; }
.value-desc { font-size:13px; color:var(--ink-muted); line-height:1.65; }

/* ── Team ── */
.team-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
.team-card { background:var(--cream); border:0.5px solid var(--cream-border); border-radius:var(--radius-md); overflow:hidden; transition:transform .25s, box-shadow .25s; }
.team-card:hover { transform:translateY(-4px); box-shadow:0 8px 24px rgba(0,0,0,0.08); }
.team-img-wrap { height:220px; overflow:hidden; }
.team-img-wrap img { width:100%; height:100%; object-fit:cover; object-position:top; transition:transform .5s; }
.team-card:hover .team-img-wrap img { transform:scale(1.04); }
.team-body { padding:18px 20px; }
.team-name { font-family:var(--font-display); font-size:17px; font-weight:400; color:var(--ink); margin-bottom:4px; }
.team-role { font-size:12px; color:var(--red); text-transform:uppercase; letter-spacing:0.8px; font-weight:500; }

/* ── CTA Strip ── */
.cta-strip { background:var(--ink); padding:64px 0; }
.cta-inner { display:flex; align-items:center; gap:40px; }
.cta-inner h2 { font-family:var(--font-display); font-size:32px; font-weight:400; color:white; flex:1; }
.cta-inner p { font-size:15px; color:rgba(255,255,255,0.55); flex:2; line-height:1.6; }
.btn-cta { background:var(--red); color:white; font-size:14px; font-weight:500; padding:13px 28px; border-radius:var(--radius-pill); white-space:nowrap; transition:background .25s, transform .25s; }
.btn-cta:hover { background:var(--red-dark); transform:translateY(-1px); }

@media(max-width:900px) {
  .two-col { grid-template-columns:1fr; gap:48px; }
  .col-visual { display:none; }
  .values-grid { grid-template-columns:repeat(2,1fr); }
  .team-grid { grid-template-columns:repeat(2,1fr); }
  .cta-inner { flex-direction:column; gap:20px; text-align:center; }
}
@media(max-width:600px) {
  .section-pad { padding:56px 0; }
  .values-grid, .team-grid { grid-template-columns:1fr; }
}
</style>
