---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const impatti = [
  { importo: "€10", desc: "Finanzia il materiale didattico per un corso BLSD" },
  { importo: "€25", desc: "Copre le spese per uno screening cardiologico" },
  { importo: "€50", desc: "Supporta l'organizzazione di un evento pubblico" },
  { importo: "€100", desc: "Contribuisce all'acquisto di un defibrillatore DAE" },
];

const faq = [
  { q: "La donazione è deducibile fiscalmente?", r: "Sì. Le donazioni ad associazioni APS sono detraibili al 30% fino a €30.000 oppure deducibili dal reddito imponibile. Ti invieremo ricevuta fiscale." },
  { q: "Come posso ricevere la ricevuta?", r: "Dopo la donazione riceverai via email una ricevuta fiscale valida ai fini della dichiarazione dei redditi." },
  { q: "Posso donare con bonifico bancario?", r: "Sì. Per il bonifico contattaci a info@cuoreinmente.it e ti forniremo i dati bancari dell'associazione." },
  { q: "Posso fare una donazione ricorrente?", r: "Al momento accettiamo donazioni una tantum. Per contributi ricorrenti contattaci direttamente." },
];
---

<Layout title="Dona ora" description="Sostieni CuoreinMente APS con una donazione. Il tuo contributo aiuta a salvare vite e promuovere la salute a Savigliano.">
  <Nav />

  <main>
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="page-hero-bg">
        <img src="https://images.unsplash.com/photo-1469571486292-0ba58a3f068b?w=1400&q=75&auto=format&fit=crop" alt="Dona ora" loading="eager" />
        <div class="page-hero-overlay"></div>
      </div>
      <div class="container page-hero-content">
        <div class="breadcrumb">
          <a href="/">Home</a><span>/</span><span>Dona ora</span>
        </div>
        <h1 class="page-title">Dona e cambia<br /><em>davvero qualcosa.</em></h1>
        <p class="page-subtitle">Ogni contributo, grande o piccolo, ci permette di organizzare corsi, eventi e attività di prevenzione aperte a tutti.</p>
      </div>
    </section>

    <!-- Donazione -->
    <section class="dona-section">
      <div class="container dona-grid">

        <!-- Importo + form -->
        <div class="dona-form-wrap">
          <h2 class="form-title">Scegli il tuo contributo</h2>

          <div class="amount-grid">
            <button class="amount-btn" data-amount="10">€10</button>
            <button class="amount-btn active" data-amount="25">€25</button>
            <button class="amount-btn" data-amount="50">€50</button>
            <button class="amount-btn" data-amount="100">€100</button>
          </div>

          <div class="amount-custom-wrap">
            <label for="customAmount">Oppure inserisci un importo personalizzato</label>
            <div class="custom-input-wrap">
              <span class="euro-sign">€</span>
              <input type="number" id="customAmount" min="1" placeholder="Altro importo" />
            </div>
          </div>

          <div class="donate-methods">
            <h3 class="methods-title">Metodo di pagamento</h3>
            <div class="methods-grid">
              <label class="method-card active">
                <input type="radio" name="method" value="card" checked />
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                Carta di credito
              </label>
              <label class="method-card">
                <input type="radio" name="method" value="paypal" />
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 11l2.5-6.5A3.5 3.5 0 0 1 13 3h3.5A3.5 3.5 0 0 1 20 6.5v1A3.5 3.5 0 0 1 16.5 11H12l-1 5H8z"/></svg>
                PayPal
              </label>
              <label class="method-card">
                <input type="radio" name="method" value="bonifico" />
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                Bonifico
              </label>
            </div>
          </div>

          <button class="btn-dona-main" id="donateBtn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
            <span id="donateBtnText">Dona €25</span>
          </button>

          <div class="dona-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Pagamento sicuro · Ricevuta fiscale garantita · Detraibile al 30%
          </div>
        </div>

        <!-- Impatto -->
        <div class="impatto-col">
          <div class="eyebrow">A cosa serve il tuo contributo</div>
          <h2 class="section-h2">La tua donazione<br /><em>in concreto</em></h2>
          <div class="impatto-list">
            {impatti.map(i => (
              <div class="impatto-item">
                <div class="impatto-importo">{i.importo}</div>
                <p class="impatto-desc">{i.desc}</p>
              </div>
            ))}
          </div>
          <div class="trust-box">
            <div class="trust-badge">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Associazione certificata APS
            </div>
            <p>CuoreinMente è una Associazione di Promozione Sociale regolarmente registrata. Tutti i fondi raccolti sono destinati esclusivamente alle attività dell'associazione.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <div class="eyebrow" style="text-align:center">Hai domande?</div>
        <h2 class="section-h2" style="text-align:center;margin-bottom:48px">Domande frequenti</h2>
        <div class="faq-list">
          {faq.map((f, i) => (
            <details class="faq-item" open={i === 0}>
              <summary class="faq-q">
                {f.q}
                <svg class="faq-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="faq-a">{f.r}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.page-hero { position:relative; min-height:400px; display:flex; align-items:flex-end; padding-bottom:64px; background:#111; overflow:hidden; }
.page-hero-bg { position:absolute; inset:0; }
.page-hero-bg img { width:100%; height:100%; object-fit:cover; opacity:0.45; }
.page-hero-overlay { position:absolute; inset:0; background:linear-gradient(135deg, rgba(192,57,43,0.7) 0%, rgba(10,5,5,0.8) 60%); }
.page-hero-content { position:relative; z-index:10; }
.breadcrumb { display:flex; gap:8px; align-items:center; font-size:12px; color:rgba(255,255,255,0.4); margin-bottom:20px; }
.breadcrumb a { color:rgba(255,255,255,0.5); }
.page-title { font-family:var(--font-display); font-size:clamp(40px,5.5vw,68px); font-weight:400; color:white; margin-bottom:12px; }
.page-title em { font-style:italic; color:#F5C4B3; }
.page-subtitle { font-size:16px; color:rgba(255,255,255,0.65); max-width:480px; line-height:1.65; }

.dona-section { padding:88px 0; }
.dona-grid { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start; }
.form-title { font-family:var(--font-display); font-size:24px; font-weight:400; color:var(--ink); margin-bottom:24px; }

.amount-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:20px; }
.amount-btn { background:var(--cream); border:0.5px solid var(--cream-border); color:var(--ink); font-family:var(--font-body); font-size:15px; font-weight:500; padding:14px 8px; border-radius:var(--radius-sm); cursor:pointer; transition:all .2s; }
.amount-btn:hover, .amount-btn.active { background:var(--red); color:white; border-color:var(--red); }

.amount-custom-wrap { margin-bottom:28px; }
.amount-custom-wrap label { display:block; font-size:12px; font-weight:500; color:var(--ink-faint); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px; }
.custom-input-wrap { display:flex; align-items:center; background:white; border:0.5px solid var(--cream-border); border-radius:var(--radius-sm); overflow:hidden; transition:border-color .2s; }
.custom-input-wrap:focus-within { border-color:var(--red); box-shadow:0 0 0 3px rgba(192,57,43,0.08); }
.euro-sign { padding:0 12px; font-size:16px; color:var(--ink-muted); background:var(--cream); border-right:0.5px solid var(--cream-border); height:44px; display:flex; align-items:center; }
.custom-input-wrap input { border:none; outline:none; padding:0 14px; font-size:15px; font-family:var(--font-body); color:var(--ink); width:100%; height:44px; background:transparent; }

.methods-title { font-size:12px; font-weight:500; color:var(--ink-faint); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:12px; }
.methods-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:28px; }
.method-card { display:flex; flex-direction:column; align-items:center; gap:6px; padding:14px 8px; background:var(--cream); border:0.5px solid var(--cream-border); border-radius:var(--radius-sm); cursor:pointer; font-size:12px; color:var(--ink-muted); transition:all .2s; }
.method-card input { display:none; }
.method-card.active { border-color:var(--red); background:var(--red-light); color:var(--red); }
.method-card:hover { border-color:var(--red); }

.btn-dona-main { display:flex; align-items:center; justify-content:center; gap:8px; background:var(--red); color:white; font-family:var(--font-body); font-size:15px; font-weight:500; padding:16px 32px; border-radius:var(--radius-pill); border:none; cursor:pointer; width:100%; transition:background .25s, transform .25s; box-shadow:0 4px 20px rgba(192,57,43,0.3); margin-bottom:14px; }
.btn-dona-main:hover { background:var(--red-dark); transform:translateY(-1px); }

.dona-note { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--ink-faint); justify-content:center; }

/* Impatto */
.eyebrow { font-size:11px; font-weight:500; color:var(--red); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:12px; }
.section-h2 { font-family:var(--font-display); font-size:clamp(28px,3.5vw,40px); font-weight:400; color:var(--ink); margin-bottom:24px; }
.section-h2 em { font-style:italic; color:var(--red); }
.impatto-list { display:flex; flex-direction:column; gap:14px; margin-bottom:32px; }
.impatto-item { display:flex; align-items:center; gap:16px; padding:16px 20px; background:var(--cream); border:0.5px solid var(--cream-border); border-radius:var(--radius-sm); }
.impatto-importo { font-family:var(--font-display); font-size:22px; color:var(--red); min-width:52px; }
.impatto-desc { font-size:14px; color:var(--ink-muted); line-height:1.5; }
.trust-box { background:var(--ink); color:white; border-radius:var(--radius-md); padding:24px 22px; }
.trust-badge { display:flex; align-items:center; gap:8px; font-size:13px; font-weight:500; margin-bottom:10px; }
.trust-box p { font-size:13px; color:rgba(255,255,255,0.55); line-height:1.65; }

/* FAQ */
.faq-section { padding:88px 0; background:var(--cream); border-top:0.5px solid var(--cream-border); }
.faq-list { max-width:720px; margin:0 auto; display:flex; flex-direction:column; gap:12px; }
.faq-item { background:white; border:0.5px solid var(--cream-border); border-radius:var(--radius-sm); overflow:hidden; }
.faq-q { display:flex; justify-content:space-between; align-items:center; gap:16px; padding:18px 22px; font-size:15px; font-weight:500; color:var(--ink); cursor:pointer; list-style:none; transition:background .2s; }
.faq-q:hover { background:var(--cream); }
.faq-q::-webkit-details-marker { display:none; }
.faq-arrow { transition:transform .25s; flex-shrink:0; }
details[open] .faq-arrow { transform:rotate(180deg); }
.faq-a { padding:0 22px 20px; font-size:14px; color:var(--ink-muted); line-height:1.7; }

@media(max-width:900px) {
  .dona-grid { grid-template-columns:1fr; gap:48px; }
  .amount-grid { grid-template-columns:repeat(2,1fr); }
}
</style>

<script>
const amountBtns = document.querySelectorAll('.amount-btn');
const donateBtn = document.getElementById('donateBtnText');
const customInput = document.getElementById('customAmount') as HTMLInputElement;
let selectedAmount = 25;

amountBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    amountBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    selectedAmount = parseInt(btn.getAttribute('data-amount') || '25');
    if (donateBtn) donateBtn.textContent = `Dona €${selectedAmount}`;
    if (customInput) customInput.value = '';
  });
});

customInput?.addEventListener('input', () => {
  const val = parseInt(customInput.value);
  if (val > 0) {
    amountBtns.forEach(b => b.classList.remove('active'));
    if (donateBtn) donateBtn.textContent = `Dona €${val}`;
    selectedAmount = val;
  }
});

const methodCards = document.querySelectorAll('.method-card');
methodCards.forEach(card => {
  card.addEventListener('click', () => {
    methodCards.forEach(c => c.classList.remove('active'));
    card.classList.add('active');
  });
});
</script>
